# CityFreshKart — client production build (VPS-shaped template)
# Generate + sync VAPID: npm run setup:env
# Then: npm run build
#
# API + uploads base URL:
# - Same host as the SPA: omit REACT_APP_API_URL or set it to your public site URL (both OK).
# - API on another subdomain: set REACT_APP_API_URL=https://api.yourdomain.com at build time.
# Local dev: leave unset — publicOrigin uses localhost:<REACT_APP_API_PORT or 5000> when the
# dev server port differs. Optional: REACT_APP_API_PORT=5006 if the server uses PORT=5006.

# Same origin as site (recommended for apex + www): leave unset to use browser origin.
# Set this only when API is intentionally hosted on a different domain/subdomain.
# REACT_APP_API_URL=https://api.cityfreshkart.com

REACT_APP_APP_NAME=CityFreshKart
REACT_APP_APP_DESCRIPTION=Fresh produce delivered from local farms
REACT_APP_APP_EMAIL=hello@cityfreshkart.com
REACT_APP_APP_PHONE=+91-9999999999

REACT_APP_DEFAULT_CURRENCY=INR
REACT_APP_DEFAULT_LANGUAGE=en

REACT_APP_MAX_FILE_SIZE=5242880
REACT_APP_API_TIMEOUT_MS=60000
REACT_APP_SUPPORTED_IMAGE_TYPES=image/jpeg,image/png,image/webp

REACT_APP_WHATSAPP_NUMBER=919999999999

REACT_APP_FACEBOOK_URL=https://facebook.com/cityfreshkart
REACT_APP_TWITTER_URL=https://twitter.com/cityfreshkart
REACT_APP_INSTAGRAM_URL=https://instagram.com/cityfreshkart
REACT_APP_YOUTUBE_URL=https://youtube.com/@cityfreshkart

# Web Push public key (must match server VAPID_PUBLIC_KEY)
REACT_APP_VAPID_PUBLIC_KEY=__AUTO_VAPID_PUBLIC_KEY__

# Firebase — only if REACT_APP_AUTH_PROVIDER=firebase
# REACT_APP_AUTH_PROVIDER=
# REACT_APP_FIREBASE_API_KEY=
# REACT_APP_FIREBASE_AUTH_DOMAIN=
# REACT_APP_FIREBASE_PROJECT_ID=
# REACT_APP_FIREBASE_APP_ID=
# REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
