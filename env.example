# Server Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Frontend Auth Provider
REACT_APP_AUTH_PROVIDER=
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=luxury_ecommerce
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production

# Firebase Admin Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# File Upload Configuration (bytes). Nginx client_max_body_size should be larger (e.g. 8m).
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Email Configuration (Optional - for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Security
CORS_ORIGIN=http://localhost:3000
# Extra origins for Helmet CSP connect-src (comma-separated). Use when the browser loads the SPA from
# one host and calls the API on another (e.g. https://www.example.com,https://api.example.com).
CSP_CONNECT_SRC=
# Global /api limit (per IP per window). Auth, GET /api/health, GET /api/settings are excluded from this limiter.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# Reverse proxy: number of hops (e.g. 1 for Nginx in front of Node). Used with trust proxy for accurate IP-based limits.
TRUST_PROXY_HOPS=1

# Auth routes only (login/register). Successful responses are not counted. Override in production if needed.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=50

# Client build (set in client/.env.production before npm run build)
# REACT_APP_API_URL=https://api.yourdomain.com
