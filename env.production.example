# CityFreshKart — production / VPS-shaped server env (template)
# Generate secrets: npm run setup:env
# Testing (weak fixed secrets, local/VPS smoke only): npm run setup:env:testing
# Never commit the real .env file.

NODE_ENV=production
PORT=5006

CLIENT_URL=https://cityfreshkart.com
CORS_ORIGIN=https://cityfreshkart.com

# Optional: Helmet CSP when SPA and API are on different hosts
# CSP_CONNECT_SRC=https://cityfreshkart.com

# DB — use DATABASE_URL or DB_* (not both unless you know the precedence in config.js)
# DATABASE_URL=postgresql://cityfreshkart_user:PASSWORD@localhost:5432/cityfreshkart
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cityfreshkart
DB_USER=cityfreshkart_user
DB_PASSWORD=__AUTO_DB_PASSWORD__

JWT_SECRET=__AUTO_JWT_SECRET__

# Razorpay — replace with your keys (test or live)
RAZORPAY_KEY_ID=__EDIT_RAZORPAY_KEY_ID__
RAZORPAY_KEY_SECRET=__EDIT_RAZORPAY_KEY_SECRET__

MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Global /api limit (per IP). GET /api/health, GET /api/settings, and /api/auth are excluded.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# Trust X-Forwarded-For from one reverse proxy (Nginx, Cloudflare, etc.)
TRUST_PROXY_HOPS=1

# Login/register: max failed attempts per window (successful logins do not count)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=50

ADMIN_PHONE=9999999999
ADMIN_PASSWORD=__AUTO_ADMIN_PASSWORD__

# Firebase Admin (for Google login token verification)
# Prefer single JSON var in production:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Or split keys:
FIREBASE_PROJECT_ID=cityfreshkart-33442
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Web Push (filled by setup:env when web-push is installed)
VAPID_PUBLIC_KEY=__AUTO_VAPID_PUBLIC_KEY__
VAPID_PRIVATE_KEY=__AUTO_VAPID_PRIVATE_KEY__
VAPID_SUBJECT=mailto:hello@cityfreshkart.com

# Optional — only if you wire these features
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# REDIS_URL=redis://localhost:6379
