{
  "name": "luxury-ecommerce",
  "version": "1.0.0",
  "description": "Luxury e-commerce website inspired by Tiffany & Co.",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "build:prod": "cd client && npm run build",
    "start": "NODE_ENV=production node server/index.js",
    "start:prod": "NODE_ENV=production node server/index.js",
    "test:prod": "npm run build:prod && npm run start:prod",
    "test:prod:build": "npm run build:prod",
    "install-all": "npm install && cd client && npm install",
    "seed": "node server/database/seed.js",
    "db:setup": "node server/database/setup.js",
    "lint": "eslint client/src/ server/ --ext .js,.jsx",
    "lint:fix": "eslint client/src/ server/ --ext .js,.jsx --fix",
    "lint:client": "eslint client/src/ --ext .js,.jsx",
    "lint:server": "eslint server/ --ext .js",
    "security:audit": "npm audit",
    "security:audit:fix": "npm audit fix",
    "test:security": "npx audit-ci --config audit-ci.json",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:auth": "playwright test tests/auth.spec.js",
    "test:products": "playwright test tests/products.spec.js",
    "test:cart": "playwright test tests/cart.spec.js",
    "test:checkout": "playwright test tests/checkout.spec.js",
    "test:e2e": "playwright test tests/e2e.spec.js",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project='Mobile Chrome'"
  },
  "keywords": [
    "ecommerce",
    "luxury",
    "jewelry",
    "tiffany"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "pg": "^8.11.3",
    "razorpay": "^2.9.2",
    "sharp": "^0.34.4",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.23.3",
    "@babel/preset-react": "^7.23.3",
    "@playwright/test": "^1.58.2",
    "audit-ci": "^7.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-security": "^1.7.1",
    "nodemon": "^3.0.2"
  }
}
